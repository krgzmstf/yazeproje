# ──────────────────────────────────────────────────────────────
# YAZE Proje – .gitignore
# ──────────────────────────────────────────────────────────────

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ── Virtual Environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment / Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Docker ───────────────────────────────────────────────────
docker-compose.override.yml

# ── Node.js / Frontend ──────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Database ─────────────────────────────────────────────────
*.sqlite3
*.db

# ── Uploads ──────────────────────────────────────────────────
uploads/
media/

# ── Testing / Coverage ──────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/

# ── SSL Certificates ────────────────────────────────────────
nginx/ssl/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
