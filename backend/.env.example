# ──────────────────────────────────────────────────────────────
# YAZE Proje – Environment Variables
# Copy this file to .env and fill in the actual values.
# ──────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME=YAZE Proje API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-string
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database (PostgreSQL) ────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=yaze_user
POSTGRES_PASSWORD=yaze_password
POSTGRES_DB=yaze_db

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET_KEY=jwt-change-me-to-a-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yazeproje.com
SMTP_FROM_NAME=YAZE Proje
SMTP_TLS=true

# ── SMS (Netgsm) ────────────────────────────────────────────
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=

# ── Scraping ─────────────────────────────────────────────────
SCRAPER_INTERVAL_MINUTES=60
SCRAPER_USER_AGENT=YazeBot/1.0

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
